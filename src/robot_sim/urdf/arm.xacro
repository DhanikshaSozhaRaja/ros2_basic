<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="robot_arm">

<link name="arm_link">

  <visual>
    <geometry>
      <box size="0.05 0.05 0.30"/>
    </geometry>
  </visual>

  <collision>
    <geometry>
      <box size="0.05 0.05 0.30"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="1"/>
    <origin xyz="0 0 0"/>
    <inertia ixx="0.01" iyy="0.01" izz="0.01"
             ixy="0" ixz="0" iyz="0"/>
  </inertial>

</link>

<joint name="arm_joint"
       type="revolute">

  <parent link="base_link"/>
  <child link="arm_link"/>

  <origin xyz="0 0 0.225"/>

  <axis xyz="0 1 0"/>

  <limit lower="-1.57"
         upper="1.57"
         effort="20"
         velocity="1"/>

</joint>

</xacro:macro>

</robot>
